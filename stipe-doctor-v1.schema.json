{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/stipe-doctor-v1.schema.json",
  "title": "stipe-doctor-v1",
  "description": "Stipe emits a versioned doctor report for Cap via `stipe doctor --json`. Producer: stipe doctor command. Consumer: cap (health status panel).",
  "type": "object",
  "required": ["schema_version", "healthy", "summary", "checks", "repair_actions"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "healthy":        { "type": "boolean" },
    "summary":        { "type": "string" },
    "install_profile": {
      "type": "object",
      "required": ["profile", "config_path"],
      "properties": {
        "profile": { "type": "string" },
        "config_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "passed"],
        "properties": {
          "name":    { "type": "string" },
          "passed":  { "type": "boolean" },
          "message": { "type": ["string", "null"] },
          "repair_actions": {
            "type": "array",
            "items": { "$ref": "#/$defs/repair_action" }
          }
        },
        "additionalProperties": false
      }
    },
    "repair_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/repair_action" }
    },
    "hook_paths": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event", "path", "passed"],
        "properties": {
          "event": { "type": "string" },
          "path": { "type": "string" },
          "passed": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "drift": {
      "type": "object",
      "properties": {
        "baseline_path": { "type": "string" },
        "generated_at_unix_nanos": { "type": "integer" },
        "findings": { "type": "array" }
      },
      "additionalProperties": true
    },
    "developer_tools": {
      "type": "object",
      "additionalProperties": true
    },
    "provider_health": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["host", "provider", "available", "healthy", "status", "auth_freshness"],
        "properties": {
          "host": { "type": "string" },
          "provider": { "type": "string" },
          "available": { "type": "boolean" },
          "healthy": { "type": "boolean" },
          "status": { "type": "string" },
          "auth_freshness": { "type": "string", "enum": ["fresh", "stale", "missing", "unknown"] },
          "auth_detail": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "mcp_health": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["host", "required_servers", "healthy", "status", "auth_freshness"],
        "properties": {
          "host": { "type": "string" },
          "config_paths": { "type": "array", "items": { "type": "string" } },
          "required_servers": { "type": "array", "items": { "type": "string" } },
          "registered_servers": { "type": "array", "items": { "type": "string" } },
          "missing_servers": { "type": "array", "items": { "type": "string" } },
          "healthy": { "type": "boolean" },
          "status": { "type": "string" },
          "auth_freshness": { "type": "string", "enum": ["fresh", "stale", "missing", "unknown"] }
        },
        "additionalProperties": false
      }
    },
    "runtime_policy": {
      "type": "object",
      "required": ["configured", "precedence"],
      "properties": {
        "configured": { "type": "boolean" },
        "config_paths": { "type": "array", "items": { "type": "string" } },
        "precedence": {
          "type": "array",
          "items": { "$ref": "#/$defs/policy_scope" }
        },
        "load_error": { "type": ["string", "null"] },
        "remembered_decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/remembered_decision" }
        },
        "active_install_profile": {
          "anyOf": [
            { "$ref": "#/$defs/remembered_decision" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "package_inventory": {
      "type": "object",
      "required": ["package_metadata_available"],
      "properties": {
        "package_metadata_available": { "type": "boolean" },
        "metadata_sources": { "type": "array", "items": { "type": "string" } },
        "discovered_packages": { "type": "array", "items": { "type": "string" } },
        "discovered_plugins": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "worktree_config": {
      "type": "object",
      "required": ["detected"],
      "properties": {
        "detected": { "type": "boolean" },
        "project_root": { "type": ["string", "null"] },
        "discovered_configs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "package_drift": {
      "type": "object",
      "required": ["metadata_available"],
      "properties": {
        "metadata_available": { "type": "boolean" },
        "expected_packages": { "type": "array", "items": { "type": "string" } },
        "installed_packages": { "type": "array", "items": { "type": "string" } },
        "missing_packages": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "mcp_server_health": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name":   { "type": "string" },
          "status": { "type": "string", "enum": ["not-installed", "installed-not-responding", "running"] },
          "detail": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "api_key_health": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "status", "note"],
        "properties": {
          "provider": { "type": "string" },
          "status":   { "type": "string", "enum": ["configured", "missing", "unexpected-format"] },
          "note":     { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "plugin_inventory": {
      "type": "object",
      "required": ["annulus_validator_used", "items", "skills_count", "hooks_count", "stale_count", "missing_count"],
      "properties": {
        "annulus_validator_used": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/plugin_inventory_item" }
        },
        "skills_count":  { "type": "integer" },
        "hooks_count":   { "type": "integer" },
        "stale_count":   { "type": "integer" },
        "missing_count": { "type": "integer" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "repair_action": {
      "type": "object",
      "required": ["command", "label", "description", "args", "tier"],
      "properties": {
        "action_key":  { "type": ["string", "null"] },
        "args":        { "type": "array", "items": { "type": "string" } },
        "command":     { "type": "string" },
        "description": { "type": ["string", "null"] },
        "label":       { "type": "string" },
        "tier":        { "type": "string", "enum": ["primary", "secondary", "manual"] }
      },
      "additionalProperties": false
    },
    "policy_scope": {
      "type": "string",
      "enum": ["project", "user"]
    },
    "policy_decision": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "decision_source": {
      "type": "string",
      "enum": ["operator-profile", "operator-policy-file", "imported-config"]
    },
    "remembered_decision": {
      "type": "object",
      "required": ["subject", "scope", "decision", "source", "updated_at_unix"],
      "properties": {
        "subject": { "type": "string" },
        "scope": { "$ref": "#/$defs/policy_scope" },
        "decision": { "$ref": "#/$defs/policy_decision" },
        "source": { "$ref": "#/$defs/decision_source" },
        "updated_at_unix": { "type": "integer" },
        "note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "plugin_inventory_item": {
      "type": "object",
      "required": ["name", "category", "path_status", "version_drift"],
      "properties": {
        "name":              { "type": "string" },
        "category":          { "type": "string" },
        "path_status":       { "type": "string", "enum": ["valid", "stale", "missing"] },
        "installed_version": { "type": ["string", "null"] },
        "version_drift":     { "type": "string", "enum": ["up-to-date", "behind", "unknown"] },
        "pinned_version":    { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  }
}
