{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/mycelium-gain-v1.schema.json",
  "title": "Mycelium Gain v1",
  "description": "Mycelium emits token-savings analytics and recent command history to Cap via `mycelium gain --format json` and `mycelium gain --history --format json`. Producer: mycelium/src/gain/export.rs. Consumer: cap/server/mycelium/gain.ts.",
  "type": "object",
  "required": ["schema_version", "summary", "by_command"],
  "properties": {
    "schema_version": {
      "const": "1.0",
      "description": "Contract version. Consumers should reject unknown versions."
    },
    "summary": {
      "type": "object",
      "required": [
        "avg_savings_pct",
        "avg_time_ms",
        "total_commands",
        "total_input",
        "total_output",
        "total_saved",
        "total_time_ms"
      ],
      "properties": {
        "avg_savings_pct": { "type": "number" },
        "avg_time_ms": { "type": "integer", "minimum": 0 },
        "total_commands": { "type": "integer", "minimum": 0 },
        "total_input": { "type": "integer", "minimum": 0 },
        "total_output": { "type": "integer", "minimum": 0 },
        "total_saved": { "type": "integer", "minimum": 0 },
        "total_time_ms": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "by_command": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["avg_savings_pct", "command", "count", "exec_time_ms", "input_tokens", "tokens_saved"],
        "properties": {
          "avg_savings_pct": { "type": "number" },
          "command": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 0 },
          "exec_time_ms": { "type": "integer", "minimum": 0 },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "tokens_saved": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["command", "input_tokens", "output_tokens", "project_path", "saved_tokens", "savings_pct", "timestamp"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "project_path": { "type": "string" },
          "saved_tokens": { "type": "integer", "minimum": 0 },
          "savings_pct": { "type": "number" },
          "session_id": { "type": ["string", "null"] },
          "timestamp": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "daily": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "avg_time_ms",
          "commands",
          "date",
          "input_tokens",
          "output_tokens",
          "saved_tokens",
          "savings_pct",
          "total_time_ms"
        ],
        "properties": {
          "avg_time_ms": { "type": "integer", "minimum": 0 },
          "commands": { "type": "integer", "minimum": 0 },
          "date": { "type": "string", "minLength": 1 },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "saved_tokens": { "type": "integer", "minimum": 0 },
          "savings_pct": { "type": "number" },
          "total_time_ms": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "weekly": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["avg_time_ms", "commands", "date", "input_tokens", "output_tokens", "saved_tokens", "savings_pct", "total_time_ms"],
        "properties": {
          "avg_time_ms":   { "type": "integer", "minimum": 0 },
          "commands":      { "type": "integer", "minimum": 0 },
          "date":          { "type": "string", "minLength": 1, "description": "ISO week start date (YYYY-MM-DD)." },
          "input_tokens":  { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "saved_tokens":  { "type": "integer", "minimum": 0 },
          "savings_pct":   { "type": "number" },
          "total_time_ms": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "monthly": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["avg_time_ms", "commands", "date", "input_tokens", "output_tokens", "saved_tokens", "savings_pct", "total_time_ms"],
        "properties": {
          "avg_time_ms":   { "type": "integer", "minimum": 0 },
          "commands":      { "type": "integer", "minimum": 0 },
          "date":          { "type": "string", "minLength": 1, "description": "ISO month start date (YYYY-MM-01)." },
          "input_tokens":  { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "saved_tokens":  { "type": "integer", "minimum": 0 },
          "savings_pct":   { "type": "number" },
          "total_time_ms": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
