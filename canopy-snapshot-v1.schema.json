{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/canopy-snapshot-v1.schema.json",
  "title": "canopy-snapshot-v1",
  "description": "Canopy emits a versioned attention snapshot for Cap via `canopy snapshot --format json`. Producer: canopy/src/api.rs (snapshot endpoint). Consumer: cap (dashboard status).",
  "type": "object",
  "required": ["schema_version", "attention", "sla_summary", "tasks", "evidence"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "attention": {
      "type": "object",
      "required": [
        "actionable_handoffs", "actionable_tasks", "agents_needing_attention",
        "critical_tasks", "handoffs_needing_attention", "stale_agents",
        "stale_handoffs", "tasks_needing_attention"
      ],
      "properties": {
        "actionable_handoffs":        { "type": "integer", "minimum": 0 },
        "actionable_tasks":           { "type": "integer", "minimum": 0 },
        "agents_needing_attention":   { "type": "integer", "minimum": 0 },
        "critical_tasks":             { "type": "integer", "minimum": 0 },
        "handoffs_needing_attention": { "type": "integer", "minimum": 0 },
        "stale_agents":               { "type": "integer", "minimum": 0 },
        "stale_handoffs":             { "type": "integer", "minimum": 0 },
        "tasks_needing_attention":    { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "sla_summary": {
      "type": "object",
      "required": ["breach_severity", "due_soon_count", "overdue_count"],
      "properties": {
        "breach_severity":       { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
        "due_soon_count":        { "type": "integer", "minimum": 0 },
        "oldest_overdue_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "overdue_count":         { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "title", "status"],
        "properties": {
          "task_id": { "type": "string" },
          "title":   { "type": "string" },
          "status":  { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "evidence-ref-v1.schema.json" }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent_id", "status"],
        "properties": {
          "agent_id": { "type": "string" },
          "name": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["idle", "assigned", "in_progress", "blocked", "review_required"] },
          "current_task_id": { "type": ["string", "null"] },
          "last_heartbeat": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["handoff_id", "from_agent", "to_agent", "status"],
        "properties": {
          "handoff_id": { "type": "string" },
          "from_agent": { "type": "string" },
          "to_agent": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["pending", "accepted", "completed", "rejected"] },
          "task_id": { "type": ["string", "null"] },
          "created_at": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "operator_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "action_type"],
        "properties": {
          "action_id": { "type": "string" },
          "action_type": { "type": "string" },
          "target_task_id": { "type": ["string", "null"] },
          "target_agent_id": { "type": ["string", "null"] },
          "status": { "type": "string", "enum": ["pending", "applied", "rejected"] },
          "created_at": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
