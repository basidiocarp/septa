{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/hyphae-memoir-inspect-v1.schema.json",
  "title": "hyphae-memoir-inspect-v1",
  "description": "Hyphae emits versioned memoir inspection payloads for Cap via `hyphae memoir inspect <memoir> --concept <name> --json`.",
  "type": "object",
  "required": ["schema_version", "memoir", "concept", "depth", "neighborhood"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "memoir": {
      "type": "object",
      "required": ["id", "name", "description", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "consolidation_threshold": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "concept": {
      "type": "object",
      "required": ["id", "memoir_id", "name", "definition"],
      "properties": {
        "id": { "type": "string" },
        "memoir_id": { "type": "string" },
        "name": { "type": "string" },
        "definition": { "type": "string" }
      },
      "additionalProperties": false
    },
    "depth": { "type": "integer", "minimum": 0 },
    "neighborhood": {
      "type": "object",
      "required": ["concepts", "links"],
      "properties": {
        "concepts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "memoir_id", "name", "definition"],
            "properties": {
              "id": { "type": "string" },
              "memoir_id": { "type": "string" },
              "name": { "type": "string" },
              "definition": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "links": { "type": "array" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
