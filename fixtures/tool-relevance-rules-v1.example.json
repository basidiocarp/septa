{
  "schema_version": "1.0",
  "rules": [
    {
      "operation": "Write",
      "file_pattern": "**/*.rs",
      "recommended_tools": [
        {
          "tool_name": "hyphae_memory_recall",
          "source": "hyphae",
          "reason": "Check for past errors or patterns before modifying Rust source."
        },
        {
          "tool_name": "rhizome_get_symbols",
          "source": "rhizome",
          "reason": "Verify symbol names and types before editing Rust files."
        }
      ],
      "severity": "recommended",
      "check_window": "session"
    },
    {
      "operation": "Edit",
      "file_pattern": "**/*.rs",
      "recommended_tools": [
        {
          "tool_name": "rhizome_find_references",
          "source": "rhizome",
          "reason": "Check callers before modifying function signatures."
        }
      ],
      "severity": "recommended",
      "check_window": "session"
    },
    {
      "operation": "git_commit",
      "recommended_tools": [
        {
          "tool_name": "hyphae_memory_store",
          "source": "hyphae",
          "reason": "Store session decisions and outcomes before committing."
        }
      ],
      "severity": "optional",
      "check_window": "recent_10"
    },
    {
      "operation": "Bash",
      "command_pattern": "cargo *",
      "recommended_tools": [
        {
          "tool_name": "hyphae_memory_recall",
          "source": "hyphae",
          "reason": "Recall past build errors for this project before running cargo commands."
        }
      ],
      "severity": "recommended",
      "check_window": "recent_5"
    }
  ]
}
