{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/hyphae-health-v1.schema.json",
  "title": "hyphae-health-v1",
  "description": "Hyphae emits versioned health summaries for Cap via `hyphae health --json`.",
  "type": "object",
  "required": ["schema_version", "topics"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": ["string", "null"] },
    "requested_topic": { "type": ["string", "null"] },
    "total_topics": { "type": "integer", "minimum": 0 },
    "topics_needing_consolidation": { "type": "integer", "minimum": 0 },
    "total_stale_entries": { "type": "integer", "minimum": 0 },
    "topics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "entry_count", "avg_weight"],
        "properties": {
          "topic": { "type": "string" },
          "entry_count": { "type": "integer", "minimum": 0 },
          "avg_weight": { "type": "number" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
