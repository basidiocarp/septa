{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/schemas/task-output-v1",
  "title": "Task Output V1",
  "description": "Structured output from a completed canopy task.",
  "type": "object",
  "required": ["schema_version", "status", "raw"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "task-output-v1" },
    "status": { "type": "string", "enum": ["success", "failed", "skipped"] },
    "raw": { "type": "string" },
    "json": { "oneOf": [{ "type": "object" }, { "type": "null" }] },
    "usage": {
      "type": "object",
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "tool_calls": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "reason": { "type": "string" }
  }
}
