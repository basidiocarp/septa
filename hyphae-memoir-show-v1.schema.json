{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/hyphae-memoir-show-v1.schema.json",
  "title": "hyphae-memoir-show-v1",
  "description": "Hyphae emits versioned memoir detail payloads for Cap via `hyphae memoir show <memoir> --json`.",
  "type": "object",
  "required": ["schema_version", "memoir", "total", "concepts"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "memoir": {
      "type": "object",
      "required": ["id", "name", "description", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "consolidation_threshold": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "stats": {
      "type": "object",
      "required": ["total_concepts", "total_links", "avg_confidence", "label_counts"],
      "properties": {
        "total_concepts": { "type": "integer", "minimum": 0 },
        "total_links": { "type": "integer", "minimum": 0 },
        "avg_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "label_counts": { "type": "array" }
      },
      "additionalProperties": false
    },
    "query": {
      "anyOf": [
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "limit": { "type": "integer", "minimum": 0 },
    "offset": { "type": "integer", "minimum": 0 },
    "total": { "type": "integer", "minimum": 0 },
    "concepts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "memoir_id", "name", "definition"],
        "properties": {
          "id": { "type": "string" },
          "memoir_id": { "type": "string" },
          "name": { "type": "string" },
          "definition": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
