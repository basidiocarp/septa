{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/hyphae-sources-v1.schema.json",
  "title": "hyphae-sources-v1",
  "description": "Hyphae emits versioned ingestion-source snapshots for Cap via `hyphae list-sources --json`.",
  "type": "object",
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "project": { "type": ["string", "null"] },
    "total_sources": { "type": "integer", "minimum": 0 },
    "total_chunks": { "type": "integer", "minimum": 0 },
    "sources": { "type": "array" }
  },
  "additionalProperties": true
}
