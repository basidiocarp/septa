{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/usage-event-v1.schema.json",
  "title": "usage-event-v1",
  "description": "Normalized usage event contract for Basidiocarp tools. First producer boundary: Cortina transcript and lifecycle capture. First deterministic summary consumer: Mycelium. Operator-facing consumer: Cap usage and cost surfaces.",
  "type": "object",
  "required": [
    "schema_version",
    "event_kind",
    "captured_at_unix",
    "tool_name",
    "runtime",
    "scope",
    "usage",
    "origin"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "event_kind": {
      "type": "string",
      "enum": ["session_usage"]
    },
    "captured_at_unix": {
      "type": "integer",
      "minimum": 0
    },
    "tool_name": {
      "$ref": "host-identifier-v1.schema.json",
      "description": "Host-facing tool identity."
    },
    "runtime": {
      "type": "string",
      "minLength": 1,
      "description": "Execution runtime or provider identity used to produce the usage event."
    },
    "scope": {
      "type": "object",
      "required": ["project_scope", "project_root", "worktree_id", "workflow_identity"],
      "properties": {
        "project_scope": {
          "type": "string",
          "enum": ["global", "project", "worktree"]
        },
        "project_root": {
          "type": ["string", "null"]
        },
        "worktree_id": {
          "type": ["string", "null"]
        },
        "workflow_identity": {
          "anyOf": [
            { "$ref": "workflow-participant-runtime-identity-v1.schema.json" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "usage": {
      "type": "object",
      "required": [
        "requests",
        "input_tokens",
        "output_tokens",
        "cache_creation_input_tokens",
        "cache_read_input_tokens",
        "total_tokens"
      ],
      "properties": {
        "requests": {
          "type": "integer",
          "minimum": 0
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cache_creation_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cache_read_input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": ["number", "null"],
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "origin": {
      "type": "object",
      "required": ["producer", "source_kind", "source_ref"],
      "properties": {
        "producer": {
          "type": "string",
          "minLength": 1
        },
        "source_kind": {
          "type": "string",
          "enum": ["transcript", "statusline", "hook_summary", "import"]
        },
        "source_ref": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
