{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/hyphae-memoir-search-v1.schema.json",
  "title": "hyphae-memoir-search-v1",
  "description": "Hyphae emits versioned memoir search payloads for Cap via `hyphae memoir search <query> --json`.",
  "type": "object",
  "required": ["schema_version", "query", "total", "results"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "memoir": {
      "anyOf": [
        {
          "type": "object",
          "required": ["id", "name", "description", "created_at", "updated_at"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "description": { "type": "string" },
            "created_at": { "type": "string", "format": "date-time" },
            "updated_at": { "type": "string", "format": "date-time" },
            "consolidation_threshold": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ]
    },
    "query": { "type": "string" },
    "limit": { "type": "integer", "minimum": 0 },
    "offset": { "type": "integer", "minimum": 0 },
    "total": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "memoir_id", "name", "definition"],
        "properties": {
          "id": { "type": "string" },
          "memoir_id": { "type": "string" },
          "name": { "type": "string" },
          "definition": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
