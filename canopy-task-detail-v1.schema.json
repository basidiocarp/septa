{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basidiocarp.dev/septa/canopy-task-detail-v1.schema.json",
  "title": "canopy-task-detail-v1",
  "description": "Canopy emits a versioned task detail payload for Cap via `canopy task get <id> --format json`. Producer: canopy/src/api.rs (task detail endpoint). Consumer: cap (task detail view).",
  "type": "object",
  "required": ["schema_version", "task", "attention", "sla_summary", "allowed_actions", "evidence"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "task": {
      "type": "object",
      "required": ["task_id", "title", "status"],
      "properties": {
        "task_id":     { "type": "string" },
        "title":       { "type": "string" },
        "status":      { "type": "string" },
        "description": { "type": ["string", "null"] },
        "agent_id":    { "type": ["string", "null"] },
        "created_at":  { "type": ["string", "null"] },
        "updated_at":  { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "attention": {
      "type": "object",
      "required": ["task_id", "level", "reasons"],
      "properties": {
        "task_id": { "type": "string" },
        "level":   { "type": "string", "enum": ["normal", "needs_attention", "critical"] },
        "reasons": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "sla_summary": {
      "type": "object",
      "required": ["task_id", "breach_severity", "due_soon_count", "overdue_count"],
      "properties": {
        "task_id":               { "type": "string" },
        "breach_severity":       { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
        "due_soon_count":        { "type": "integer", "minimum": 0 },
        "overdue_count":         { "type": "integer", "minimum": 0 },
        "oldest_overdue_seconds": { "type": ["integer", "null"], "minimum": 0 },
        "highest_risk_queue":    { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action_id", "kind", "target_kind", "level", "title", "summary"],
        "properties": {
          "action_id": { "type": "string" },
          "kind": { "type": "string" },
          "target_kind": { "type": "string" },
          "level": { "type": "string", "enum": ["normal", "needs_attention", "critical"] },
          "task_id": { "type": ["string", "null"] },
          "handoff_id": { "type": ["string", "null"] },
          "agent_id": { "type": ["string", "null"] },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "due_at": { "type": ["string", "null"], "format": "date-time" },
          "expires_at": { "type": ["string", "null"], "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": { "$ref": "evidence-ref-v1.schema.json" }
    },
    "relationships": {
      "type": "array",
      "items": { "type": "object" }
    },
    "related_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "title", "status"],
        "properties": {
          "task_id": { "type": "string" },
          "title":   { "type": "string" },
          "status":  { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "events": {
      "type": "array",
      "description": "Task event timeline. Each event has at minimum an event_type; additional shape is producer-defined and may evolve.",
      "items": {
        "type": "object",
        "required": ["event_type"],
        "properties": {
          "event_type": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "heartbeats": {
      "type": "array",
      "description": "Per-agent heartbeat events for this task. Producer-defined item shape; consumers should treat unknown fields as forward-compatible.",
      "items": { "type": "object" }
    },
    "heartbeat_summary": {
      "type": "object",
      "description": "Aggregate heartbeat metrics for the task (count, last_heartbeat, etc.).",
      "additionalProperties": true
    },
    "agent_heartbeat_summaries": {
      "type": "array",
      "description": "Per-agent heartbeat summaries.",
      "items": { "type": "object" }
    },
    "ownership": {
      "type": "object",
      "description": "Current task ownership / assignment summary.",
      "additionalProperties": true
    },
    "assignments": {
      "type": "array",
      "description": "Active and historical task assignments.",
      "items": { "type": "object" }
    },
    "handoffs": {
      "type": "array",
      "description": "Handoffs originating from this task.",
      "items": { "type": "object" }
    },
    "handoff_attention": {
      "type": "array",
      "description": "Per-handoff attention signals (stale, overdue, etc.).",
      "items": { "type": "object" }
    },
    "operator_actions": {
      "type": "array",
      "description": "Operator-facing actions emitted alongside allowed_actions for richer dashboard rendering.",
      "items": { "type": "object" }
    },
    "workflow_context": {
      "type": ["object", "null"],
      "description": "Optional workflow / queue context (queue_state, etc.). Null when the task isn't part of a tracked workflow.",
      "additionalProperties": true
    },
    "relationship_summary": {
      "type": "object",
      "description": "Aggregate counts derived from relationships (blocker_count, open_follow_up_child_count, etc.).",
      "additionalProperties": true
    },
    "children": {
      "type": "array",
      "description": "Direct child tasks of this task.",
      "items": { "type": "object" }
    },
    "children_complete": {
      "type": "boolean",
      "description": "True when every child task is in a terminal state."
    },
    "parent_id": {
      "type": ["string", "null"],
      "description": "Parent task identifier, or null if this is a root task."
    }
  },
  "additionalProperties": false
}
